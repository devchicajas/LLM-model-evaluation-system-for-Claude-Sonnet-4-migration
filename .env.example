# PostgreSQL (e.g. Neon)
DATABASE_URL=postgresql://user:password@host/dbname
# After setting DATABASE_URL, create tables once: npm run db:schema

# Optional: include retiring Claude Sonnet 4 as a 4th scored run (same prompts) for comparison.
# Not compatible with EVAL_FREE_TIER. OpenRouter: uses OPENROUTER_BASELINE_SLUG. Direct API: Anthropic.
# EVAL_BASELINE_SONNET4=false
# OPENROUTER_BASELINE_SLUG=anthropic/claude-sonnet-4
# BASELINE_ANTHROPIC_MODEL=claude-sonnet-4

# Dashboard server port (npm run ui)
# EVAL_UI_PORT=3847

# ─── Option A — Direct APIs (default) ─────────────────────────────────────
# Requires EVAL_OPENROUTER=false (or unset) and EVAL_FREE_TIER=false.
# If EVAL_OPENROUTER=true, the pipeline uses OPENROUTER_API_KEY + slugs, not these vendor keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional direct-mode tuning (ignored when EVAL_OPENROUTER or EVAL_FREE_TIER is true):
# Anthropic judge model id (must NOT be one of STANDARD_EVAL_MODEL_IDS). Default: claude-opus-4-7 from code.
# DIRECT_JUDGE_MODEL_ID=claude-haiku-4-5
# Hard p95 latency gate (ms): models above this fail eligibility. Omit to disable.
# MAX_P95_LATENCY_MS=60000
# JSON map category → weight for averaging dimension scores (default weight 1 per category).
# EVAL_CATEGORY_WEIGHTS={"debugging":1.5,"compliance":1.3,"operations":1.2}

# ─── Option B — OpenRouter (one key, OpenAI-compatible routing) ───────────
# Set to true to use OPENROUTER_API_KEY only (still need DATABASE_URL).
# Docs: https://openrouter.ai/docs
EVAL_OPENROUTER=false
OPENROUTER_API_KEY=
# Exactly three OpenRouter model slugs, comma-separated (defaults match our benchmark intent)
# OPENROUTER_CANDIDATE_MODELS=openai/gpt-4o-mini,anthropic/claude-sonnet-4.6,google/gemini-2.5-flash
# Judge must not be one of the three candidates above
# OPENROUTER_JUDGE_MODEL=google/gemini-2.5-pro
# Optional OpenRouter attribution headers
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_APP_TITLE=model-eval

# ─── Option C — Google-only “free tier style” (no Anthropic/OpenAI keys) ───
EVAL_FREE_TIER=false
# FREE_JUDGE_MODEL_ID=gemini-2.5-flash
